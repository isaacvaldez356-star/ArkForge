<Window x:Class="ArkForge.App.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ArkForge.App.ViewModels"
        Title="ArkForge" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI Variable">

    <Window.DataContext>
        <vm:ShellViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menú lateral -->
        <StackPanel Grid.Column="0" Background="{StaticResource SurfaceBrush}">

            <TextBlock Text="ArkForge" 
                       Foreground="White" 
                       FontSize="22" 
                       FontWeight="Bold"
                       Margin="20,20,20,30"/>

            <Button Content="Dashboard" Command="{Binding ShowDashboardCommand}" 
                    Height="40" Margin="10,2" Background="Transparent" Foreground="White" 
                    BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0"/>

            <Button Content="Servidor" Command="{Binding ShowServerCommand}" 
                    Height="40" Margin="10,2" Background="Transparent" Foreground="White" 
                    BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0"/>

            <Button Content="Mods" Command="{Binding ShowModsCommand}" 
                    Height="40" Margin="10,2" Background="Transparent" Foreground="White" 
                    BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0"/>

            <Button Content="Configuración" Command="{Binding ShowConfigurationCommand}" 
                    Height="40" Margin="10,2" Background="Transparent" Foreground="White" 
                    BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0"/>

            <Button Content="Backups" Command="{Binding ShowBackupCommand}" 
                    Height="40" Margin="10,2" Background="Transparent" Foreground="White" 
                    BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0"/>

            <Button Content="Consola" Command="{Binding ShowConsoleCommand}" 
                    Height="40" Margin="10,2" Background="Transparent" Foreground="White" 
                    BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0"/>

            <Button Content="Ajustes" Command="{Binding ShowSettingsCommand}" 
                    Height="40" Margin="10,2" Background="Transparent" Foreground="White" 
                    BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0"/>

        </StackPanel>

        <!-- Área de contenido -->
        <ContentControl Grid.Column="1" 
                         Content="{Binding CurrentView}" 
                         Margin="20"/>

    </Grid>
</Window>